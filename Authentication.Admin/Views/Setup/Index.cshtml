@model SetupViewModel
@inject Authentication.Admin.AdminOptions Options
@{
    ViewData["Title"] = "First administrator";
    Layout = "_CenteredLayout";
}

<!-- Setup Card -->
<div class="card bg-secondary border-0 mb-0">
    <div class="card-header bg-transparent pb-3">
        <div class="text-center">
            <div class="icon icon-shape bg-gradient-primary text-white rounded-circle mb-3 mx-auto">
                <i class="ni ni-key-25"></i>
            </div>
            <h2 class="mb-0">Create the first administrator</h2>
            <p class="text-muted mt-2 mb-0">
                <small>This page is available only until an administrator exists, then it seals itself.</small>
            </p>
        </div>
    </div>
    <div class="card-body px-lg-5 py-lg-4">
        <form asp-controller="Setup" asp-action="Index" method="post" role="form">
            <div asp-validation-summary="All" class="text-danger text-center mb-3"></div>

            <div class="form-group mb-3">
                <div class="input-group input-group-merge input-group-alternative">
                    <div class="input-group-prepend">
                        <span class="input-group-text"><i class="ni ni-email-83"></i></span>
                    </div>
                    <input asp-for="Email" class="form-control" placeholder="Email" autocomplete="username" />
                </div>
            </div>

            <div class="form-group mb-3" data-hide-when-promote>
                <div class="input-group input-group-merge input-group-alternative">
                    <div class="input-group-prepend">
                        <span class="input-group-text"><i class="ni ni-lock-circle-open"></i></span>
                    </div>
                    <input asp-for="Password" class="form-control" placeholder="Password (new admin)" autocomplete="new-password" />
                </div>
            </div>

            <div class="custom-control custom-control-alternative custom-checkbox mb-3">
                <input asp-for="PromoteExisting" class="custom-control-input" id="promoteExisting" data-toggle-promote />
                <label class="custom-control-label" for="promoteExisting">
                    <span class="text-muted">Promote an existing user (they already have a password)</span>
                </label>
            </div>

            @if (!string.IsNullOrEmpty(Options.SetupToken))
            {
                <div class="form-group mb-3">
                    <div class="input-group input-group-merge input-group-alternative">
                        <div class="input-group-prepend">
                            <span class="input-group-text"><i class="ni ni-badge"></i></span>
                        </div>
                        <input asp-for="SetupToken" class="form-control" placeholder="Setup secret" autocomplete="off" />
                    </div>
                    <small class="text-muted">This deployment requires the setup secret.</small>
                </div>
            }

            <div class="text-center">
                <button type="submit" class="btn btn-primary my-3">Create administrator</button>
            </div>
        </form>
    </div>
</div>
