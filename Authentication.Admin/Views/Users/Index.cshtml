@model AdminUserPage
@{
    ViewData["Title"] = "Users";
}

<!-- Users Header -->
<div class="d-flex align-items-center mb-4">
    <div>
        <h1 class="h2 mb-0">Users</h1>
        <p class="text-muted mb-0">@Model.TotalCount total.</p>
    </div>
    <form class="form-inline ml-auto" asp-controller="Users" asp-action="Index" method="get">
        <div class="input-group input-group-sm">
            <input type="search" name="search" value="@Model.Search" class="form-control" placeholder="Search email" />
            <div class="input-group-append">
                <button class="btn btn-primary" type="submit"><i class="ni ni-zoom-split-in"></i></button>
            </div>
        </div>
    </form>
</div>

<!-- Users Table -->
<div class="card">
    <div class="table-responsive">
        <table class="table align-items-center table-flush">
            <thead class="thead-light">
                <tr>
                    <th>Email</th>
                    <th>Confirmed</th>
                    <th>Two-factor</th>
                    <th>Status</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @if (Model.Users.Count == 0)
                {
                    <tr><td colspan="5" class="text-center text-muted py-4">No users match.</td></tr>
                }
                else
                {
                    foreach (AdminUserSummary user in Model.Users)
                    {
                        <tr>
                            <td>@user.Email</td>
                            <td>
                                @if (user.EmailConfirmed)
                                {
                                    <span class="badge badge-success">Confirmed</span>
                                }
                                else
                                {
                                    <span class="badge badge-warning">Unconfirmed</span>
                                }
                            </td>
                            <td>
                                @if (user.TwoFactorEnabled)
                                {
                                    <span class="badge badge-info">On</span>
                                }
                                else
                                {
                                    <span class="badge badge-secondary">Off</span>
                                }
                            </td>
                            <td>
                                @if (user.LockedOut)
                                {
                                    <span class="badge badge-danger">Locked</span>
                                }
                                else
                                {
                                    <span class="badge badge-success">Active</span>
                                }
                            </td>
                            <td class="text-right">
                                <a class="btn btn-sm btn-neutral" asp-controller="Users" asp-action="Details" asp-route-id="@user.Id">Manage</a>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>

    @if (Model.TotalPages > 1)
    {
        <div class="card-footer d-flex justify-content-between align-items-center">
            <small class="text-muted">Page @Model.Page of @Model.TotalPages</small>
            <nav>
                <ul class="pagination pagination-sm mb-0">
                    <li class="page-item @(Model.HasPrevious ? "" : "disabled")">
                        <a class="page-link" asp-controller="Users" asp-action="Index"
                           asp-route-search="@Model.Search" asp-route-page="@(Model.Page - 1)">Prev</a>
                    </li>
                    <li class="page-item @(Model.HasNext ? "" : "disabled")">
                        <a class="page-link" asp-controller="Users" asp-action="Index"
                           asp-route-search="@Model.Search" asp-route-page="@(Model.Page + 1)">Next</a>
                    </li>
                </ul>
            </nav>
        </div>
    }
</div>
